<%- include('partials/head', { pageTitle: 'PO Templates', styles: ['admin.css', 'po-line-items.css'] }) %>
<%- include('partials/header', { pageTitle: 'PO Templates' }) %>

<main class="container">
  <div class="card form-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <input id="filterInput" class="filter-input" placeholder="Search templates..." />
      <button class="btn btn-primary" id="addTemplateBtn">+ New Template</button>
    </div>

    <table class="po-table">
      <thead>
        <tr>
          <th>Template Name</th>
          <th>Stage</th>
          <th>Line Items</th>
          <th style="width: 160px;">Actions</th>
        </tr>
      </thead>
      <tbody id="templateTable"></tbody>
    </table>
  </div>

  <!-- Add/Edit Template Modal -->
  <div id="templateModal" class="modal" style="display:none;">
    <div class="modal-content" style="width: 800px; max-width: 95vw;">
      <h2 id="templateModalTitle">New Template</h2>

      <form id="templateForm">
        <input type="hidden" id="templateId">

        <div class="form-row">
          <div>
            <label for="templateName">Template Name</label>
            <input type="text" id="templateName" required placeholder="e.g. Standard Electrical Package">
          </div>
        </div>

        <div class="form-row">
          <div>
            <label for="templateStage">Stage (optional)</label>
            <select id="templateStage">
              <option value="">No stage</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div>
            <label for="templateDeliveryNotes">Delivery Notes (optional)</label>
            <textarea id="templateDeliveryNotes" placeholder="Delivery instructions, site access details, etc." rows="3" class="form-control"></textarea>
          </div>
        </div>

        <div class="line-items-section" style="display: block;">
          <label style="font-weight: 500; margin-bottom: 8px; display: block;">Line Items</label>
          <table class="line-items-table">
            <thead>
              <tr>
                <th>Description</th>
                <th style="width: 90px; text-align: right;">Qty</th>
                <th style="width: 90px;">Unit</th>
                <th style="width: 120px; text-align: right;">Unit Cost</th>
                <th style="width: 60px;"></th>
              </tr>
            </thead>
            <tbody id="templateLineItemsBody"></tbody>
          </table>
          <div class="line-items-actions">
            <button type="button" id="addTemplateLineItem" class="btn btn-outline-secondary btn-sm">Add Line Item</button>
          </div>
          <datalist id="templateLineItemSuggestions"></datalist>
        </div>

        <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem; justify-content: flex-end;">
          <button type="button" class="btn btn-secondary" id="cancelTemplateBtn">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Template</button>
        </div>
      </form>
    </div>
  </div>
</main>

<%- include('partials/footer', { scripts: ['/ui.js', '/cost-item-lookup.js', 'po-templates.js'], includeNavScript: true }) %>
