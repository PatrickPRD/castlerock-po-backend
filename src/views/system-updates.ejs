<%- include('partials/head', { pageTitle: 'System Updates', styles: ['admin.css', 'system-updates.css'] }) %>
<%- include('partials/header', { pageTitle: 'System Updates' }) %>

<main class="container py-4">

  <!-- Environment Banner -->
  <div id="envBanner" class="alert d-none mb-4">
    <div class="d-flex align-items-center justify-content-between">
      <div>
        <i class="bi bi-info-circle me-2"></i>
        <strong id="envLabel">Loading...</strong>
        <span id="envVersion" class="ms-3 badge bg-secondary">—</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- DEV SECTION — Create Update Packages                   -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <div id="devSection" class="d-none">
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="mb-0"><i class="bi bi-box-seam me-2"></i>Create Update Package</h3>
      </div>
      <div class="card-body">
        <p class="text-muted mb-3">
          Generate an update package containing all changes since the last build.
          This package can be uploaded to any production instance regardless of its current version.
        </p>
        <button id="btnCreatePackage" class="btn btn-primary" onclick="createUpdatePackage()">
          <i class="bi bi-download me-1"></i> Generate &amp; Download Update Package
        </button>
        <div id="createProgress" class="mt-3 d-none">
          <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
          <span>Building update package...</span>
        </div>
        <div id="createResult" class="mt-3 d-none"></div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- PROD SECTION — Upload & Apply Updates                  -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <div id="prodSection" class="d-none">

    <!-- Upload & Analyze -->
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="mb-0"><i class="bi bi-cloud-upload me-2"></i>Upload Update</h3>
      </div>
      <div class="card-body">
        <p class="text-muted mb-3">
          Upload a <code>.ctupdate</code> file to analyze and apply changes to this instance.
        </p>

        <div class="mb-3">
          <input type="file" id="updateFileInput" class="form-control" accept=".ctupdate" onchange="onFileSelected()">
        </div>

        <button id="btnAnalyze" class="btn btn-outline-primary me-2" onclick="analyzeUpdate()" disabled>
          <i class="bi bi-search me-1"></i> Analyze Update
        </button>

        <div id="analyzeProgress" class="mt-3 d-none">
          <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
          <span>Analyzing update package...</span>
        </div>
      </div>
    </div>

    <!-- Analysis Results -->
    <div id="analysisCard" class="card mb-4 d-none">
      <div class="card-header bg-info text-white">
        <h3 class="mb-0"><i class="bi bi-clipboard-data me-2"></i>Update Analysis</h3>
      </div>
      <div class="card-body">
        <div id="analysisContent"></div>

        <hr>

        <div class="d-flex gap-2">
          <button id="btnApply" class="btn btn-success" onclick="applyUpdate()">
            <i class="bi bi-check-circle me-1"></i> Confirm &amp; Apply Update
          </button>
          <button class="btn btn-outline-secondary" onclick="cancelUpdate()">
            <i class="bi bi-x-circle me-1"></i> Cancel
          </button>
        </div>

        <div id="applyProgress" class="mt-3 d-none">
          <div class="spinner-border spinner-border-sm text-success me-2" role="status"></div>
          <span>Applying update...</span>
        </div>
        <div id="applyResult" class="mt-3 d-none"></div>
      </div>
    </div>

    <!-- Server Controls -->
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="mb-0"><i class="bi bi-gear-wide-connected me-2"></i>Server Controls</h3>
      </div>
      <div class="card-body">
        <p class="text-muted mb-3">
          After applying an update, restart the server to load the new code.
          If the update includes new dependencies, use "NPM Install &amp; Restart" to install them first.
        </p>

        <div class="d-flex gap-2 flex-wrap">
          <button id="btnRestart" class="btn btn-warning" onclick="restartServer()">
            <i class="bi bi-arrow-clockwise me-1"></i> Restart Server
          </button>
          <button id="btnNpmRestart" class="btn btn-danger" onclick="npmInstallAndRestart()">
            <i class="bi bi-box me-1"></i> NPM Install &amp; Restart
          </button>
        </div>

        <div id="serverProgress" class="mt-3 d-none">
          <div class="spinner-border spinner-border-sm text-warning me-2" role="status"></div>
          <span id="serverProgressText">Processing...</span>
        </div>
      </div>
    </div>
  </div>

</main>

<script src="auth-utils.js"></script>
<script src="admin-nav.js"></script>
<script src="system-updates.js"></script>
