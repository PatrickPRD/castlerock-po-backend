<%- include('partials/head', { pageTitle: 'Location Report', styles: ['location-report.css'] }) %>
<%- include('partials/header', { pageTitle: 'Inc. Labour (€)' }) %>

<main class="container">
  <div class="card">
    <div class="report-controls mb-3">
      <div class="d-flex justify-content-between align-items-center">
        <div class="row g-2 report-filters align-items-md-center flex-grow-1">
          <div class="col-12 col-md-4 form-group">
            <label for="siteFilter">Site</label>
            <select id="siteFilter">
              <option value="">All Sites</option>
            </select>
          </div>
          <div class="col-12 col-md-4 form-group">
            <label for="locationFilter">Location</label>
            <select id="locationFilter">
              <option value="">All Locations</option>
            </select>
          </div>
          <div class="col-12 col-md-auto spread-toggle text-md-start">
            <label class="checkbox-row mb-0">
              <input type="checkbox" id="showSpreadLocations">
              Show Spread Locations
            </label>
          </div>
        </div>
        <button class="btn btn-outline-primary" onclick="exportExcel()">Export to Excel</button>
      </div>
    </div>
  </div>
  <div class="card report-table-card">
    <div id="reportLoading" class="loading-overlay" aria-hidden="true">
      <div class="loading-spinner" aria-label="Loading"></div>
    </div>
    <table class="po-table">
      <thead>
        <tr>
          <th class="sortable" data-sort="site">Site <span class="sort-indicator"></span></th>
          <th class="sortable" data-sort="location">Location <span class="sort-indicator"></span></th>
          <th class="sortable" data-sort="total">Total Net (<span data-currency-symbol>€</span>) <span class="sort-indicator"></span></th>
          <th class="sortable" data-sort="labour">Inc. Labour (<span data-currency-symbol>€</span>) <span class="sort-indicator"></span></th>
          <th class="sortable" data-sort="salePrice">Sale Price (<span data-currency-symbol>€</span>) <span class="sort-indicator"></span></th>
          <th class="sortable" data-sort="expectedSpent">Expected Spend (<span data-currency-symbol>€</span>) <span class="sort-indicator"></span></th>
          <th class="sortable" data-sort="targetProfit">Target Profit (<span data-currency-symbol>€</span>) <span class="sort-indicator"></span></th>
          <th class="sortable" data-sort="targetPct">Target % <span class="sort-indicator"></span></th>
          <th class="sortable" data-sort="profitLoss">Actual Profit (<span data-currency-symbol>€</span>) <span class="sort-indicator"></span></th>
          <th class="sortable" data-sort="profitPct">Actual % <span class="sort-indicator"></span></th>
        </tr>
      </thead>
      <tbody id="reportTable"></tbody>
    </table>
  </div>
</main>

<div id="totalsBar" class="totals-bar">
  <div>
    <strong>Locations:</strong>
    <span id="locCount">0</span>
  </div>
  <div>
    <strong>Sites:</strong>
    <span id="siteCount">0</span>
  </div>
  <div>
    <strong>Total Spend:</strong>
    <span id="barTotalNet"><span data-currency-symbol>€</span>0</span>
  </div>
  <div>
    <strong>Expended Spend:</strong>
    <span id="barExpendedSpend"><span data-currency-symbol>€</span>0</span>
  </div>
  <div>
    <strong>Sales:</strong>
    <span id="barTotalSales"><span data-currency-symbol>€</span>0</span>
  </div>
  <div>
    <strong>Expected Profit:</strong>
    <span id="barExpectedProfit"><span data-currency-symbol>€</span>0</span>
    <span id="barExpectedProfitPct">0.0%</span>
  </div>
  <div>
    <strong>Actual Profit:</strong>
    <span id="barActualProfit"><span data-currency-symbol>€</span>0</span>
    <span id="barActualProfitPct">0.0%</span>
  </div>
</div>

<%- include('partials/footer', { scripts: ['/ui.js', 'location-report.js'], includeNavScript: true }) %>
